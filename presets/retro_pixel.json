{
  "name": "Retro Pixel",
  "description": "Neon cyber-retro with hot pink and cyan accents, matrix rain vibes, pixel art friendly.",
  "themes": {
    "gtk": "catppuccin-mocha-pink-standard+default",
    "icon": "Tela-circle-dracula",
    "cursor": "Bibata-Modern-Ice",
    "font": "JetBrains Mono 11"
  },
  "wallpaper": "https://w.wallhaven.cc/full/l8/wallhaven-l8r6mq.jpg",
  "settings": {
    "gnome": {
      "gtk-theme": "catppuccin-mocha-pink-standard+default",
      "icon-theme": "Tela-circle-dracula",
      "font-name": "JetBrains Mono 11",
      "monospace-font": "JetBrains Mono 11",
      "color-scheme": "prefer-dark",
      "shell-theme": "catppuccin-mocha-pink-standard+default",
      "resources": {
        "theme-url": "",
        "theme-repo": "https://github.com/catppuccin/gtk",
        "theme-install-cmd": ["python3", "install.py", "mocha", "pink", "-d", "~/.themes"],
        "icon-url": "",
        "icon-repo": "https://github.com/vinceliuice/Tela-circle-icon-theme",
        "icon-install-cmd": ["./install.sh", "dracula"],
        "shell-theme-url": "",
        "shell-theme-repo": "https://github.com/catppuccin/gtk",
        "shell-theme-install-cmd": ["python3", "install.py", "mocha", "pink", "-d", "~/.themes"],
        "fonts": [
          "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/JetBrainsMono.zip"
        ]
      },
      "extensions": {
        "user-theme@gnome-shell-extensions.gcampax.github.com": {
          "url": "https://extensions.gnome.org/download-extension/user-theme@gnome-shell-extensions.gcampax.github.com.shell-extension.zip",
          "schema": "org.gnome.shell.extensions.user-theme",
          "settings": {
            "name": "catppuccin-mocha-pink-standard+default"
          }
        }
      },
      "layout": {}
    },
    "hyprland": {
      "gtk-theme": "catppuccin-mocha-pink-standard+default",
      "waybar-style": "retro",
      "rofi-theme": "retro",
      "resources": {
        "theme-url": "",
        "theme-repo": "https://github.com/catppuccin/gtk",
        "theme-install-cmd": ["python3", "install.py", "mocha", "pink", "-d", "~/.themes"],
        "icon-url": "",
        "icon-repo": "https://github.com/vinceliuice/Tela-circle-icon-theme",
        "icon-install-cmd": ["./install.sh", "dracula"],
        "cursor-url": "https://github.com/ful1e5/Bibata_Cursor/releases/download/v2.0.7/Bibata-Modern-Ice.tar.xz",
        "waybar-style-url": "",
        "rofi-theme-url": "",
        "fonts": [
          "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/JetBrainsMono.zip"
        ]
      },
      "theme": {
        "general:border_size": 2,
        "general:gaps_in": 4,
        "general:gaps_out": 8,
        "general:col.active_border": "0xffff79c6",
        "general:col.inactive_border": "0xff282a36",
        "decoration:rounding": 4,
        "decoration:blur:enabled": true,
        "decoration:blur:size": 3,
        "decoration:blur:passes": 2,
        "decoration:active_opacity": 0.95,
        "decoration:inactive_opacity": 0.85
      }
    }
  }
}
