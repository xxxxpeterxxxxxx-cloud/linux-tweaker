{
  "name": "Cyberpunk",
  "description": "Neon colors, dark theme, futuristic fonts, custom panel layout",
  "themes": {
    "gtk": "catppuccin-mocha-blue-standard+default",
    "icon": "Tela-circle-dracula",
    "cursor": "Bibata-Modern-Ice",
    "font": "JetBrains Mono 11"
  },
  "wallpaper": "https://w.wallhaven.cc/full/wq/wallhaven-wqve6r.jpg",
  "settings": {
    "gnome": {
      "gtk-theme": "catppuccin-mocha-blue-standard+default",
      "icon-theme": "Tela-circle-dracula",
      "font-name": "JetBrains Mono 11",
      "monospace-font": "JetBrains Mono 11",
      "color-scheme": "prefer-dark",
      "shell-theme": "catppuccin-mocha-blue-standard+default",
      "resources": {
        "theme-url": "",
        "theme-repo": "https://github.com/catppuccin/gtk",
        "theme-install-cmd": ["python3", "install.py", "mocha", "blue", "-d", "~/.themes"],
        "icon-url": "",
        "icon-repo": "https://github.com/vinceliuice/Tela-circle-icon-theme",
        "icon-install-cmd": ["./install.sh", "dracula"],
        "cursor-url": "https://github.com/ful1e5/Bibata_Cursor/releases/download/v2.0.7/Bibata-Modern-Ice.tar.xz",
        "shell-theme-url": "",
        "shell-theme-repo": "https://github.com/catppuccin/gtk",
        "shell-theme-install-cmd": ["python3", "install.py", "mocha", "blue", "-d", "~/.themes"],
        "fonts": [
          "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.1.1/JetBrainsMono.zip"
        ]
      },
      "extensions": {
        "dash-to-panel@jderose9.github.com": {
          "url": "https://github.com/home-sweet-gnome/dash-to-panel/releases/download/v60/dash-to-panel@jderose9.github.com_v60.zip",
          "schema": "org.gnome.shell.extensions.dash-to-panel",
          "settings": {
            "panel-positions": "{\"0\":\"TOP\"}",
            "multi-monitors": true,
            "isolate-workspaces": true,
            "show-favorites": true,
            "show-window-previews": true,
            "intelligent-hide": false
          }
        },
        "blur-my-shell@aunetx": {
          "url": "https://github.com/aunetx/blur-my-shell/releases/download/v62/blur-my-shell@aunetx.zip",
          "schema": "org.gnome.shell.extensions.blur-my-shell",
          "settings": {
            "brightness": 0.6,
            "sigma": 30
          }
        }
      },
      "layout": {}
    },
    "kde": {
      "plasma-theme": "Catppuccin-Mocha-Blue",
      "icon-theme": "Tela-circle-dracula",
      "resources": {
        "theme-url": "",
        "theme-repo": "https://github.com/catppuccin/gtk",
        "theme-install-cmd": ["python3", "install.py", "mocha", "blue", "-d", "~/.themes"],
